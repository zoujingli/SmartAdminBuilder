{
  "name": "zoujingli/smart-admin-builder",
  "description": "SmartAdmin Phar/SFX builder package for Hyperf applications.",
  "minimum-stability": "dev",
  "prefer-stable": true,
  "license": "Apache-2.0",
  "homepage": "https://hyperf.io",
  "require": {
    "php": ">=8.4",
    "ext-json": "*",
    "hyperf/command": "^3.2",
    "hyperf/contract": "^3.2",
    "nikic/php-parser": "^5.6",
    "psr/container": "^1.0 || ^2.0",
    "symfony/finder": "^7.3 || ^8.0"
  },
  "autoload": {
    "psr-4": {
      "Builder\\": "./"
    },
    "exclude-from-classmap": [
      "/tests/"
    ]
  },
  "config": {
    "sort-packages": true
  },
  "extra": {
    "branch-alias": {
      "dev-master": "3.2-dev"
    },
    "hyperf": {
      "config": "Builder\\Provider"
    }
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "phpunit/phpunit": "^13",
    "psr/log": "^3.0",
    "symfony/var-dumper": "^8.0"
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit",
    "analyse": "vendor/bin/phpstan analyse --memory-limit=1G"
  }
}
